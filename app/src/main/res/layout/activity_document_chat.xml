<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Toolbar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/surface" android:elevation="4dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:padding="@dimen/spacing_md" android:paddingTop="48dp">
        <ImageButton android:id="@+id/btn_back"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/primary" android:contentDescription="Back"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:paddingStart="@dimen/spacing_sm">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Document Chat" android:textColor="@color/text_primary"
                android:textSize="@dimen/text_xl" android:fontFamily="sans-serif-medium"/>
            <TextView android:id="@+id/tv_doc_name"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Document name" android:textColor="@color/primary"
                android:textSize="@dimen/text_sm" android:ellipsize="end" android:maxLines="1"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Document Context Banner -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/surface_variant"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="@dimen/spacing_md" android:paddingEnd="@dimen/spacing_md"
        android:paddingTop="@dimen/spacing_xs" android:paddingBottom="@dimen/spacing_xs">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📄 " android:textSize="14sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chatting based on this document's content"
            android:textColor="@color/primary" android:textSize="@dimen/text_sm"/>
    </LinearLayout>

    <!-- Messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="@dimen/spacing_md" android:clipToPadding="false"/>

    <!-- Typing Indicator -->
    <LinearLayout android:id="@+id/layout_typing"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="@dimen/spacing_md" android:paddingBottom="@dimen/spacing_xs"
        android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🤖" android:textSize="18sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text=" AI is thinking..." android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_sm"/>
    </LinearLayout>

    <!-- Input Bar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:background="@color/surface" android:elevation="8dp"
        android:padding="@dimen/spacing_sm">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_message"
            style="@style/InputLayout"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:hint="Ask about this document...">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_message"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="textMultiLine" android:maxLines="4"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btn_send"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_sm"
            app:fabSize="mini"
            android:src="@android:drawable/ic_menu_send"
            app:backgroundTint="@color/primary"
            app:tint="@color/text_on_primary"
            android:contentDescription="Send"/>
    </LinearLayout>
</LinearLayout>
