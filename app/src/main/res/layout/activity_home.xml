<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Top Greeting Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient"
        android:padding="@dimen/spacing_lg"
        android:paddingTop="48dp"
        android:paddingBottom="32dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_greeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Good Morning,"
                    android:textColor="#CCffffff"
                    android:textSize="@dimen/text_md"/>

                <TextView
                    android:id="@+id/tv_user_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Student!"
                    android:textColor="@color/text_on_primary"
                    android:textSize="@dimen/text_xxl"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ready to learn something new?"
                    android:textColor="#BBffffff"
                    android:textSize="@dimen/text_sm"/>
            </LinearLayout>

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_avatar"
                android:layout_width="@dimen/avatar_size_md"
                android:layout_height="@dimen/avatar_size_md"
                android:src="@mipmap/ic_launcher_round"
                app:civ_border_width="2dp"
                app:civ_border_color="@color/text_on_primary"/>
        </LinearLayout>

        <!-- Search Bar -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="@dimen/spacing_lg"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/spacing_md"
                android:paddingEnd="@dimen/spacing_md">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_search"
                    android:alpha="0.5"/>

                <TextView
                    android:id="@+id/tv_search_hint"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Search documents..."
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_md"
                    android:paddingStart="@dimen/spacing_xs"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Quick Actions -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/quick_actions"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_xl"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="@dimen/spacing_lg"
                android:paddingEnd="@dimen/spacing_lg"
                android:paddingTop="@dimen/spacing_lg"
                android:paddingBottom="@dimen/spacing_sm"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:rowCount="2"
                android:paddingStart="@dimen/spacing_md"
                android:paddingEnd="@dimen/spacing_md"
                android:useDefaultMargins="true">

                <!-- Upload -->
                <LinearLayout android:id="@+id/qa_upload"
                    android:layout_width="0dp" android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:orientation="vertical" android:gravity="center"
                    android:background="@drawable/bg_qa_upload" android:layout_margin="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📤" android:textSize="26sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Upload" android:textColor="@color/text_on_primary"
                        android:textSize="@dimen/text_sm" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>

                <!-- Ask AI -->
                <LinearLayout android:id="@+id/qa_ask_ai"
                    android:layout_width="0dp" android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:orientation="vertical" android:gravity="center"
                    android:background="@drawable/bg_qa_ai" android:layout_margin="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🤖" android:textSize="26sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Ask AI" android:textColor="@color/text_on_primary"
                        android:textSize="@dimen/text_sm" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>

                <!-- Quiz -->
                <LinearLayout android:id="@+id/qa_quiz"
                    android:layout_width="0dp" android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:orientation="vertical" android:gravity="center"
                    android:background="@drawable/bg_qa_quiz" android:layout_margin="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📝" android:textSize="26sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Quiz" android:textColor="@color/text_on_primary"
                        android:textSize="@dimen/text_sm" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>

                <!-- Flashcards -->
                <LinearLayout android:id="@+id/qa_flashcards"
                    android:layout_width="0dp" android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:orientation="vertical" android:gravity="center"
                    android:background="@drawable/bg_qa_flash" android:layout_margin="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🃏" android:textSize="26sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Flashcards" android:textColor="@color/text_on_primary"
                        android:textSize="@dimen/text_sm" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>

                <!-- Schedule -->
                <LinearLayout android:id="@+id/qa_schedule"
                    android:layout_width="0dp" android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:orientation="vertical" android:gravity="center"
                    android:background="@drawable/bg_qa_schedule" android:layout_margin="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📅" android:textSize="26sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Schedule" android:textColor="@color/text_on_primary"
                        android:textSize="@dimen/text_sm" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
            </GridLayout>

            <!-- Recent Documents -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/spacing_lg"
                android:paddingEnd="@dimen/spacing_lg"
                android:paddingTop="@dimen/spacing_lg">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/recent_documents"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_xl"
                    android:fontFamily="sans-serif-medium"/>
                <TextView android:id="@+id/tv_see_all_docs"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/see_all"
                    android:textColor="@color/primary"
                    android:textSize="@dimen/text_md"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_recent_docs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:paddingStart="@dimen/spacing_md"
                android:paddingEnd="@dimen/spacing_md"
                android:nestedScrollingEnabled="false"/>

            <TextView
                android:id="@+id/tv_no_docs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_documents"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_md"
                android:gravity="center"
                android:padding="@dimen/spacing_lg"
                android:visibility="gone"/>

            <!-- Upcoming Schedule -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/spacing_lg"
                android:paddingEnd="@dimen/spacing_lg"
                android:paddingTop="@dimen/spacing_lg">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/upcoming_schedule"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_xl"
                    android:fontFamily="sans-serif-medium"/>
                <TextView android:id="@+id/tv_see_all_schedule"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/see_all"
                    android:textColor="@color/primary"
                    android:textSize="@dimen/text_md"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_upcoming_schedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:paddingStart="@dimen/spacing_md"
                android:paddingEnd="@dimen/spacing_md"
                android:paddingBottom="@dimen/spacing_lg"
                android:nestedScrollingEnabled="false"/>

            <TextView
                android:id="@+id/tv_no_schedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_schedule"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_md"
                android:gravity="center"
                android:padding="@dimen/spacing_lg"
                android:visibility="gone"/>

            <View android:layout_width="match_parent" android:layout_height="80dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/nav_selector"
        app:itemTextColor="@color/nav_selector"
        android:background="@color/surface"
        app:elevation="8dp"/>
</LinearLayout>
